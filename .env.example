# Base de données (Supabase PostgreSQL en production)
DATABASE_URL="postgresql://postgres:password@db.votre-projet.supabase.co:5432/postgres"

# Sécurité
JWT_SECRET="changez-moi-par-une-cle-secrete"

# Serveur
PORT=3000

# MTN Mobile Money (sandbox par défaut)
MTN_ENV="sandbox"
MTN_API_KEY=""
MTN_API_USER=""
MTN_SUBSCRIPTION_KEY=""

# Règles financières
MIN_DEPOSIT=100
MIN_WITHDRAWAL=500
MIN_BET=20

# Google OAuth — créer un projet sur https://console.cloud.google.com
# APIs & Services → Credentials → OAuth 2.0 Client ID (Web application)
# VITE_GOOGLE_CLIENT_ID="xxxxx.apps.googleusercontent.com"
