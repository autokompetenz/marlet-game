# Base de données (Supabase PostgreSQL en production)
DATABASE_URL="postgresql://postgres:password@db.votre-projet.supabase.co:5432/postgres"

# Sécurité
JWT_SECRET="changez-moi-par-une-cle-secrete"

# Serveur
PORT=3000

# Règles financières
MIN_DEPOSIT=100
MIN_WITHDRAWAL=500
MIN_BET=20

# =========================================
# MTN Mobile Money (Bénin/Togo)
# =========================================
# 1. https://momodeveloper.mtn.com → Create API User → copier l'UUID (Consumer Key)
# 2. Create API Key → copier la clé (Consumer Secret)
# 3. Products → subscribe à "Collection" et "Disbursement"
# 4. Copier les Primary Keys (Subscription Keys)
# =========================================
MTN_ENV="sandbox"
MTN_CONSUMER_KEY=""
MTN_CONSUMER_SECRET=""
MTN_SUBSCRIPTION_KEY=""
MTN_CALLBACK_HOST=""

# =========================================
# Google OAuth
# https://console.cloud.google.com → APIs & Services → Credentials
# =========================================
# VITE_GOOGLE_CLIENT_ID="xxxxx.apps.googleusercontent.com"
