# ============================================================
# MARLET GAME - Configuration (copier vers .env)
# ============================================================

# --- Base de données (Supabase / production) ---
# URL pooler (port 6543) recommandée pour Vercel (évite épuisement connexions)
# Ne pas oublier ?pgbouncer=true pour éviter l'erreur "prepared statement already exists"
# DATABASE_URL="postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true"
# URL directe (port 5432) pour migration locale
# DATABASE_URL="postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres"
#
# Pour développement local sans Supabase, utiliser SQLite (modifier prisma/schema.prisma -> provider = "sqlite"):
# DATABASE_URL="file:./dev.db"

# --- JWT ---
JWT_SECRET="changez-moi-par-une-chaine-aleatoire-securisee"

# --- Montants minimums ---
MIN_DEPOSIT=100
MIN_WITHDRAWAL=500
MIN_BET=20

# --- MTN Mobile Money ---
# Mode: "sandbox" (test) ou "production"
MTN_ENV="production"
# Consumer Key et Secret depuis developers.mtn.com
MTN_CONSUMER_KEY="votre-consumer-key"
MTN_CONSUMER_SECRET="votre-consumer-secret"
# Optionnel : Subscription Key (non requis pour Bénin)
MTN_SUBSCRIPTION_KEY=""
# URL de callback après déploiement
MTN_CALLBACK_HOST="https://votre-domaine.vercel.app"

# --- Google OAuth ---
VITE_GOOGLE_CLIENT_ID="votre-google-client-id.apps.googleusercontent.com"
