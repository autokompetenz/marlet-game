{
  "name": "marlet-game",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "node --watch src/server.js",
    "dev:client": "npm --prefix client run dev",
    "start": "node src/server.js",
    "build": "npm --prefix client run build",
    "db:push": "prisma db push",
    "db:seed": "node prisma/seed.js",
    "db:reset": "prisma db push --force-reset && node prisma/seed.js",
    "vercel-build": "npm install && npm --prefix client ci && npx prisma generate && npm run build"
  },
  "dependencies": {
    "@prisma/client": "^6.19.3",
    "axios": "^1.7.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.0",
    "express": "^4.21.0",
    "jsonwebtoken": "^9.0.0",
    "uuid": "^10.0.0"
  },
  "devDependencies": {
    "prisma": "^6.19.3"
  }
}
